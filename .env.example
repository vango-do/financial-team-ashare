# ===== LLM 配置（SiliconFlow + DeepSeek）=====
SILICONFLOW_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3

# ===== 本地 RAG 配置 =====
MASTER_LIBRARY_ROOT=./AgentLibrary
MASTER_RAG_LOG_PATH=./outputs/retrieval_logs.jsonl
MASTER_RAG_TOP_K=6
MASTER_RAG_MIN_SCORE=0.03

# ===== 动态爬取（可选）=====
SCRAPLING_CN_LIB=
# Optional: leave empty to run without token-protected Eastmoney endpoints.
EASTMONEY_TOKEN=

# ===== 输出目录（可选）=====
OUTPUT_DIR=./outputs
DESKTOP_OUTPUT_DIR=

# ===== RAG 日志（默认不落盘 Query）=====
ENABLE_RAG_QUERY_LOGGING=false
